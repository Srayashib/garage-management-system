<style>
@media (max-width:768px){

/* Restore table layout */
.subscribers-table{
  display:table !important;
  min-width:600px;
}

.subscribers-table thead{
  display:table-header-group !important;
}

.subscribers-table tbody{
  display:table-row-group !important;
}

.subscribers-table tr{
  display:table-row !important;
}

.subscribers-table td,
.subscribers-table th{
  display:table-cell !important;
  white-space:nowrap;
}
.subscribers-table td,
.subscribers-table th {
    padding: 12px 15px;
}
/* Enable horizontal scroll */
.subscribers-table-container{
  overflow-x:auto;
  width:100%;
}

}
</style><div class="subscribers-wrapper">
  <h2>Newsletter Subscribers</h2>

  <div class="subscribers-table-container">
<table class="subscribers-table">
    <thead>
      <tr>
        <th>#</th>
        <th>Email</th>
        <th>Subscribed Date</th>
        <th>Action</th>
      </tr>
    </thead>
    <tbody>

      <% if (subscribers.length === 0) { %>
        <tr>
          <td colspan="4" style="text-align:center;">No Subscribers Found</td>
        </tr>
      <% } %>

      <% subscribers.forEach((sub, index) => { %>
        <tr>
          <td><%= (currentPage - 1) * 5 + index + 1 %></td>
          <td><%= sub.email %></td>
          <td><%= sub.createdAt.toDateString() %></td>
          <td>
            <a href="/admin/subscribers/delete/<%= sub._id %>" 
               class="delete-btn"
               onclick="return confirm('Are you sure?')">
              Delete
            </a>
          </td>
        </tr>
      <% }) %>

    </tbody>
  </table>
  

  <!-- Pagination -->
  <div class="pagination">
    <% for(let i = 1; i <= totalPages; i++) { %>
      <a href="/admin/subscribers?page=<%= i %>" 
         class="<%= currentPage === i ? 'active-page' : '' %>">
        <%= i %>
      </a>
    <% } %>
  </div>
  </div>
  

</div>