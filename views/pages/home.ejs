<script>
document.addEventListener("DOMContentLoaded", function () {

    /* SERVICES SLIDER */

    const serviceTrack = document.querySelector(".services-track");
    const serviceItems = document.querySelectorAll(".service-item");

    let serviceIndex = 0;
    const visibleServices = 3;

    setInterval(() => {

        serviceIndex++;

        if(serviceIndex > serviceItems.length - visibleServices){
            serviceIndex = 0;
        }

        const move = serviceIndex * (100 / visibleServices);

        serviceTrack.style.transform = `translateX(-${move}%)`;

    }, 4000);



    const techTrack = document.querySelector(".technician-track");
const techItems = document.querySelectorAll(".technician-item");

let techIndex = 0;
const visibleTech = 4;
const totalTech = techItems.length;

/* make track wide enough */
techTrack.style.width = (totalTech * 100 / visibleTech) + "%";

setInterval(() => {

    techIndex++;

    if (techIndex > totalTech - visibleTech) {
        techIndex = 0;
    }

    const move = techIndex * (100 / visibleTech);

    techTrack.style.transform = `translateX(-${move}%)`;

}, 3000);
});
</script>