<%- include('../partials/header', { title: event.title }) %>

<!-- Banner -->
<div class="innerbanner">
    <img src="/images/eventdetails.jpg" alt="" class="fullimg" style="    width: 100%;
    height: 550px;
    object-fit: cover;">
    <div class="bgrey-caption"></div>
    <div class="innerbanner-caption">
        <h1>Events</h1>
    </div>
</div>

<!-- Inner Section -->
<div class="innercontent">
    <div class="container">
        <div class="row">

            <!-- LEFT CONTENT -->
            <div class="col-md-8 col-sm-8 col-xs-12">
                <div class="blog-left">

                    <!-- BLOG DETAILS -->
                    <div class="blog-block">
                        <div class="blogpic">
                            <img src="<%= event.image %>" alt="<%= event.title %>">
                        </div>

                        <h3><%= event.title %></h3>

                        <h4 class="dateyear"><%= event.date %></h4>

                        <p><%= event.fullDescription %></p>
                    </div>

                    <!-- COMMENTS SECTION (SAME STYLE) -->
                    <div class="comments-section">
                        <h3>Comments</h3>

                        <% if (comments.length > 0) { %>
                            <% comments.forEach(comment => { %>

                                <h4><%= comment.name %></h4>

                                <p>
                                    Replied on 
                                    <%= new Date(comment.createdAt).toDateString() %>
                                    <br><br>
                                    <%= comment.message %>
                                </p>

                            <% }) %>
                        <% } else { %>
                            <p>No comments yet.</p>
                        <% } %>
                    </div>

                    <!-- ADD COMMENT FORM (SAME DESIGN STRUCTURE) -->
                    <div class="new-comment-section">
                        <h3>Add New Comment</h3>

                        <div class="comment-form">
                            <form action="/add-comment/<%= event._id %>" method="POST">

                                <div class="lbl01">Your Name:</div> 
                                <input type="text" name="name" required>

                                <div class="lbl01">Your Email:</div>    
                                <input type="email" name="email" required>

                                <div class="lbl01">Comment:</div>   
                                <textarea name="message" rows="10" required></textarea>                

                                <input type="submit" value="Submit">

                            </form>
                        </div>  
                    </div>

                </div>
            </div>

            <!-- RIGHT SIDEBAR -->
            <div class="col-md-4 col-sm-4 col-xs-12">
                <div class="blog-right">

                    <% related.forEach(r => { %>
                    <div class="related-block">
                        <h3>
                            <a href="/events-details/<%= r._id %>">
                                <%= r.title %>
                            </a>
                        </h3>

                        <h6><%= r.date %></h6>

                        <div class="related-block-img">
                            <a href="/events-details/<%= r._id %>">
                                <img src="<%= r.image %>" alt="">
                            </a>
                        </div>

                        <p><%= r.shortDescription.substring(0,120) %>...</p>

                        <a href="/events-details/<%= r._id %>" class="readmore-btn">
                            Read More
                        </a>
                    </div>
                    <% }) %>

                </div>
            </div>

        </div>
    </div>
</div>

<%- include('../partials/footer') %>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<% if (success) { %>
<script>
Swal.fire({
    icon: 'success',
    title: 'Comment Added!',
    text: 'Your comment has been posted successfully.',
    confirmButtonColor: '#49bbf2'
});
</script>
<% } %>