<style>
    .innerbanner {
    position: relative;
    width: 100%;
    height: 400px;
    overflow: hidden;
}

.innerbanner .fullimg {
    width: 100%;
    height: 400px;
    object-fit: cover;   /* Makes image fill properly */
}

.innerbanner-caption {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    color: #fff;
    text-align: center;
    z-index: 2;
}

.innerbanner-caption h1 {
    font-size: 48px;
    font-weight: 800;
    text-transform: uppercase;
}@media (max-width: 768px) {
    .innerbanner,
    .innerbanner .fullimg {
        height: 350px;
    }

    .innerbanner-caption h1 {
        font-size: 28px;
    }
}
/* ================================= */
/* Extra Mobile Responsive Fix       */
/* ================================= */

@media (max-width: 992px){

    .contactpage{
        display:flex;
        flex-direction:column;
        gap:25px;
    }

    .contactpage .col-md-4,
    .contactpage .col-md-7{
        width:100%;
    }

}

/* Mobile */
@media (max-width: 768px){

    .innercontent{
        padding:20px 15px;
    }

    .contactpage h2{
        font-size:24px;
        margin-bottom:15px;
    }

    .contact-block{
        margin-bottom:15px;
    }

    .contact-block h4{
        font-size:16px;
    }

    .contact-block p{
        font-size:14px;
    }

    /* FORM MOBILE BORDER */
    .contactform{
        border:2px solid #e6e6e6;
        padding:20px;
        border-radius:10px;
        background:#fff;
        box-shadow:0 5px 15px rgba(0,0,0,0.05);
    }

    .form-control{
        font-size:14px;
        padding:10px;
    }

    textarea.form-control{
        min-height:120px;
    }

    .btn-primary{
        width:100%;
        padding:12px;
        font-size:15px;
    }

}

/* Small Mobile */
@media (max-width: 480px){

    .innerbanner-caption h1{
        font-size:22px;
    }

    .contactform{
        padding:15px;
    }

}
</style><%- include('../partials/header', { title: "Contact FGarage" }) %>

<!-- Banner -->
<div class="innerbanner">
    <img src="/images/contact.jpg" alt="Contact FGarage" class="fullimg">
    <div class="innerbanner-caption">
        <h1>Contact Us</h1>
    </div>
</div>

<!-- Contact Section -->
<div class="innercontent">
    <div class="container">
        <div class="row contactpage">

            <!-- Left Contact Info -->
            <div class="col-md-4 col-sm-4 col-xs-12">
                <h2>Contact FGarage</h2>

                <div class="contact-block">
                    <h4><i class="fas fa-map-marker-alt"></i> Address</h4>
                    <p>South Florida, United States</p>
                </div>

                <div class="contact-block">
                    <h4><i class="fas fa-phone-alt"></i> Phone</h4>
                    <p><a href="tel:+1234567890">+1 234 567 890</a></p>
                </div>

                <div class="contact-block">
                    <h4><i class="fas fa-envelope"></i> Email</h4>
                    <p><a href="mailto:info@fgarage.com">info@fgarage.com</a></p>
                </div>
            </div>

            <div class="col-md-1 col-sm-1 col-xs-12"></div>

            <!-- Contact Form -->
            <div class="col-md-7 col-sm-7 col-xs-12">
                <h2>Send Us a Message</h2>

                <div class="contactform">
                    <form action="/contact" method="POST">

                        <div class="form-group">
                            <label>Your Name</label>
                            <input type="text" name="name" class="form-control" required>
                        </div>

                        <div class="form-group">
                            <label>Your Email</label>
                            <input type="email" name="email" class="form-control" required>
                        </div>

                        <div class="form-group">
                            <label>Your Message</label>
                            <textarea name="message" class="form-control" rows="5" required></textarea>
                        </div>

                        <input type="submit" value="Send Message" class="btn btn-primary">

                    </form>
                </div>
            </div>

        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<% if (success) { %>
<script>
Swal.fire({
    icon: 'success',
    title: 'Message Sent!',
    text: 'Thank you for contacting FGarage. We will get back to you soon.',
    confirmButtonColor: '#49bbf2'
});
</script>
<% } %>

<% if (error) { %>
<script>
Swal.fire({
    icon: 'error',
    title: 'Oops!',
    text: 'Something went wrong. Please try again.'
});
</script>
<% } %>
<%- include('../partials/footer') %>