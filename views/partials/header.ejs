<!doctype html>
<html>
<head>
<meta charset="utf-8">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<meta name="viewport" content="width=device-width, initial-scale=1">

<link rel="icon" href="/images/logo.jpeg" type="image/x-icon">
<title><%= title %></title>

<link href="/css/bootstrap.min.css" rel="stylesheet">
<link href="/css/jquery-ui.min.css" rel="stylesheet">
<link href="/css/style.css" rel="stylesheet">
<link href="/css/icofont.css" rel="stylesheet">
<link href="/css/font-awesome.min.css" rel="stylesheet">
<link href="/css/fontawesome-all.min.css" rel="stylesheet">
<link href="/css/menu.css" rel="stylesheet">
<link href="/css/owl-css.css" rel="stylesheet">
<link href="/css/responsive.css" rel="stylesheet">
</head>

<body>

<div class="cbp-af-header">
    <div class="header-top">
        <div class="container">
            <div class="header-social">
                <ul>
                    <li><a href="#"><i class="fab fa-facebook-f"></i></a></li>
                    <li><a href="#"><i class="fab fa-twitter"></i></a></li>
                    <li><a href="#"><i class="fab fa-instagram"></i></a></li>
                    <li><a href="#"><i class="fab fa-pinterest-p"></i></a></li>
                </ul>
            </div>
        </div>
    </div>

    <div class="header">
        <div class="container">
            <div class="row">
                <div class="col-md-3 col-sm-3 col-xs-5">
                    <div class="sitelogo">
                        <a href="/"><img src="/images/logo1.jpeg"></a>
                    </div>
                </div>

                <div class="col-md-9 col-sm-9 col-xs-7">
                    <div class="navigation">
                        <div id='cssmenu'>
                            <ul>
    <li class="<%= currentRoute === '/' ? 'active' : '' %>">
        <a href="/">Home</a>
    </li>

    <li class="<%= currentRoute === '/about' ? 'active' : '' %>">
        <a href="/about">About Us</a>
    </li>

    <li class="<%= currentRoute === '/service' ? 'active' : '' %>">
        <a href="/service">Service</a>
    </li>

    <li class="<%= currentRoute === '/events-news' ? 'active' : '' %>">
        <a href="/events-news">Events News</a>
    </li>

    <li class="<%= currentRoute === '/contact' ? 'active' : '' %>">
        <a href="/contact">Contact Us</a>
    </li>
</ul>
                        </div>
                    </div>

                    <div class="header-cart">
    <ul>
        <% if (user) { %>

            <li style="color:#000000; padding-top:8px;">
                <a href="/dashboard">Hi, <strong><%= user.name %></strong></a>
            </li>

            <!-- <li>
                <a href="/dashboard">
                    <img src="/images/user.png" alt="Dashboard">
                </a>
            </li> -->
            <li>
                <a  style="color:#000000; margin-left:10px;">
                    |
                </a>
            </li>

            <li>
                <a href="/logout" style="color:#df0101; margin-left:10px;">
                     Logout
                </a>
            </li>

        <% } else { %>

            <li>
                <a href="/login">
                    <img src="/images/user.png" alt="Login">
                </a>
            </li>

        <% } %>
    </ul>
</div>
                </div>

            </div>
        </div>
    </div>
</div>